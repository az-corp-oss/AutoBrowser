<Page x:Class="AutoBrowser.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:views="clr-namespace:AutoBrowser.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Settings"
      Background="Transparent"
      ScrollViewer.CanContentScroll="False">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Sticky Header -->
        <StackPanel Grid.Row="0" Margin="24,24,24,0">
            <ui:TextBlock FontTypography="Title" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Settings"/>
            <ui:TextBlock Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Configure application preferences and system integration"/>
        </StackPanel>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent">
            <StackPanel Margin="24,16,24,80">

                <!-- SECTION: Appearance -->
                <ui:TextBlock Margin="0,0,0,8" FontTypography="BodyStrong" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Appearance"/>
                <Border Padding="16,12" Margin="0,0,0,24" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <ui:TextBlock FontTypography="Body" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="App Theme"/>
                            <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Change the appearance mode of the application"/>
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding IsDarkTheme}" OffContent="Light" OnContent="Dark" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- SECTION: System Integration -->
                <ui:TextBlock Margin="0,0,0,8" FontTypography="BodyStrong" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="System Integration"/>
                <StackPanel Margin="0,0,0,24">
                    <!-- Default Browser -->
                    <Border Padding="16,12" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <ui:TextBlock FontTypography="Body" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Register as Default Web Browser"/>
                                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Sets AutoBrowser as the default browser for standard HTTP/HTTPS links." TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsDefaultBrowser}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Protocol Handler -->
                    <Border Padding="16,12" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <ui:TextBlock FontTypography="Body" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Register 'autobrowser://' Protocol"/>
                                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Enables routing links containing the custom protocol scheme." TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsProtocolRegistered}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- SECTION: Routing & Fallback -->
                <ui:TextBlock Margin="0,0,0,8" FontTypography="BodyStrong" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Browser Routing"/>
                <Border Padding="16,12" Margin="0,0,0,24" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <ui:TextBlock FontTypography="Body" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Fallback Web Browser"/>
                            <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="The browser that will open if no specific routing rules match." TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableBrowsers}"
                                  SelectedItem="{Binding FallbackBrowser}"
                                  DisplayMemberPath="DisplayName"
                                  Width="250" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- SECTION: Window & System Tray -->
                <ui:TextBlock Margin="0,0,0,8" FontTypography="BodyStrong" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Window &amp; System Tray"/>
                <StackPanel Margin="0,0,0,16">
                    <!-- Minimize to Tray -->
                    <Border Padding="16,12" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <ui:TextBlock FontTypography="Body" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Minimize to System Tray"/>
                                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Hides the main window to the system tray area when minimized"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding MinimizeToTray}" OffContent="Off" OnContent="On" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Close to Tray -->
                    <Border Padding="16,12" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <ui:TextBlock FontTypography="Body" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Close to System Tray"/>
                                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Keeps the app running in the system tray instead of exiting on window close"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CloseToTray}" OffContent="Off" OnContent="On" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Push Notifications -->
                    <Border Padding="16,12" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <ui:TextBlock FontTypography="Body" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Show Push Notifications"/>
                                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Show a system tray notification when a URL is routed"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowPushNotifications}" OffContent="Off" OnContent="On" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
