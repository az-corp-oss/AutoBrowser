<Page x:Class="AutoBrowser.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:views="clr-namespace:AutoBrowser.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="About"
      Background="Transparent"
      ScrollViewer.CanContentScroll="False">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Sticky Header -->
        <StackPanel Grid.Row="0" Margin="24,24,24,0">
            <ui:TextBlock FontTypography="Title" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="About"/>
            <ui:TextBlock Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Application information and credits"/>
        </StackPanel>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent">
            <StackPanel Margin="24,16,24,80">

                <!-- App Info Card -->
                <Border Padding="20" Margin="0,0,0,24" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- App Icon -->
                        <Grid Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Center">
                            <Ellipse Width="64" Height="64" Fill="{DynamicResource ControlFillColorDefaultBrush}">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.1"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <ui:SymbolIcon Symbol="Globe24" Filled="True" FontSize="36" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                        </Grid>

                        <!-- App Details -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="16,0,0,0">
                            <ui:TextBlock FontTypography="Subtitle" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="AutoBrowser"/>
                            <ui:TextBlock Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding AppVersion, StringFormat='Version {0}'}"/>
                            <ui:TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="A lightweight URL interceptor and router for Windows that directs clicks to different web browsers based on matching rules."/>
                            <ui:HyperlinkButton Margin="0,12,0,0" Content="GitHub Repository" NavigateUri="https://github.com/azhe403/AutoBrowser"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Third-Party Libraries -->
                <ui:TextBlock Margin="0,0,0,12" FontTypography="BodyStrong" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Third-Party Libraries &amp; Credits"/>

                <StackPanel>
                    <!-- WPF-UI -->
                    <Border Padding="12,10" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Library24" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <ui:TextBlock FontTypography="BodyStrong" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="WPF-UI"/>
                                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Modern Fluent Design System components and theme support for WPF applications." TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CommunityToolkit.Mvvm -->
                    <Border Padding="12,10" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Box24" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <ui:TextBlock FontTypography="BodyStrong" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="CommunityToolkit.Mvvm"/>
                                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="A modern, fast, and modular MVVM library featuring C# source generators." TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Serilog -->
                    <Border Padding="12,10" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="DocumentBulletList24" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <ui:TextBlock FontTypography="BodyStrong" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Serilog"/>
                                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Diagnostic logging library providing structured logging, Console, and file output." TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DependencyInjection -->
                    <Border Padding="12,10" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Connected24" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <ui:TextBlock FontTypography="BodyStrong" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Microsoft.Extensions.DependencyInjection"/>
                                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Standard abstraction and implementation of the dependency injection pattern in .NET." TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
