<UserControl x:Class="AutoBrowser.Views.StatusControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent"
             IsHitTestVisible="False">
    <ui:InfoBar Title="Status" Message="{Binding Status}" IsOpen="True" Severity="Informational" HorizontalAlignment="Center" MaxWidth="600" IsHitTestVisible="True"/>
</UserControl>
