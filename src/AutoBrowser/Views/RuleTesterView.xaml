<ui:FluentWindow x:Class="AutoBrowser.Views.RuleTesterView"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                Title="Input" Height="160" Width="450"
                WindowStartupLocation="CenterOwner"
                ShowInTaskbar="False"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="PromptText" Grid.Row="0" Margin="0,0,0,8"/>
        <ui:TextBox x:Name="InputBox" Grid.Row="1" Margin="0,0,0,8" Text="https://"
                    AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <ui:Button Content="OK" IsDefault="True" Width="80" Margin="0,0,8,0" Click="Ok_Click"/>
            <ui:Button Content="Cancel" IsCancel="True" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
